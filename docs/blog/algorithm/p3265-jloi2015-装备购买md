## P3265 [JLOI2015] 装备购买

	- ![1973969-20240716160121231-926330571.png](../assets/1973969-20240716160121231-926330571_1755436118627_0.png){:height 380, :width 831}
	- ![1973969-20240716160121294-1285947561.png](../assets/1973969-20240716160121294-1285947561_1755436137723_0.png){:height 333, :width 580}
	- Code：
	  ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  #define rep(i,j,k) for (int i=j;i<=k;++i)
	  const double eps=1e-5;
	  const int N=5e2+5;
	  struct node{
	  	double a[N];
	  	int w;
	  	bool operator<(const node&x)const{return w<x.w;}
	  }q[N];
	  int p[N];
	  int n,m,ans,cnt;
	  void guass(){
	  	rep(i,1,n)
	  		rep(j,1,m){
	  			if(q[i].a[j]<=eps&&q[i].a[j]>=-eps) continue;
	  			if(!p[j]){
	  				p[j]=i;//记录最高位为第j位的线性基
	  				cnt++;ans+=q[i].w;
	  				break;
	  			}
	  			else{
	  				double d=q[i].a[j]/q[p[j]].a[j];
	  				rep(k,j,m) q[i].a[k]-=d*q[p[j]].a[k];
	  			}
	  		}
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	cin>>n>>m;
	  	rep(i,1,n)
	  		rep(j,1,m) cin>>q[i].a[j];
	  	rep(i,1,n) cin>>q[i].w;
	  	sort(q+1,q+n+1);//按花费升序
	  	guass();
	  	cout<<cnt<<" "<<ans;
	  	return 0;
	  }
