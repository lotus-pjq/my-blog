	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=3e5+5;
		  struct node{
		  	int ls,rs;
		  	int sum,la;
		  }tr[N*50];
		  int n,q,id,rt;
		  void pushup(int x){
		  	tr[x].sum=tr[tr[x].ls].sum+tr[tr[x].rs].sum;
		  }
		  void pushdown(int x,int l,int r){
		  	if(tr[x].la!=-1){
		  		if(!tr[x].ls) tr[tr[x].ls=++id]={0,0,0,-1};
		  		if(!tr[x].rs) tr[tr[x].rs=++id]={0,0,0,-1};
		  		int mid=l+r>>1;
		  		tr[tr[x].ls].sum=tr[x].la*(mid-l+1);
		  		tr[tr[x].ls].la=tr[x].la;
		  		tr[tr[x].rs].sum=tr[x].la*(r-mid);
		  		tr[tr[x].rs].la=tr[x].la;
		  		tr[x].la=-1;//清除标记
		  	}
		  }
		  void change(int &p,int l,int r,int x,int y,int k){
		  	if(!p) tr[p=++id]={0,0,r-l+1,-1};
		  	if(l>=x&&r<=y){
		  		k--;k^=1;
		  		tr[p].sum=k*(r-l+1);
		  		tr[p].la=k;
		  		return;
		  	}
		  	pushdown(p,l,r);
		  	int mid=l+r>>1;
		  	if(x<=mid) change(tr[p].ls,l,mid,x,y,k);
		  	if(y>mid) change(tr[p].rs,mid+1,r,x,y,k);
		  	pushup(p);
		  }
		  signed main(){
		  	ios::sync_with_stdio(false);
		  	cin.tie(nullptr);
		  	cin>>n>>q;
		  	while(q--){
		  		int k,x,y;cin>>x>>y>>k;
		  		change(rt,1,n,x,y,k);
		  		cout<<n-tr[rt].sum<<endl;
		  	}
		  	return 0;
		  }
		  ```
	- 总结
		- 在做题时，其实对于这类数据范围较大的题目一般使用离散化处理，但是在可持久化线段树中还需要使用动态开点，所以线段树动态开点也是一项必须掌握的知识点。
