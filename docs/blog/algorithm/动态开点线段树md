- ## 用动态开点写线段树模板1
	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  const int N=2e5+5;
	  int n,m,id,rt;
	  struct node{
	      int ls,rs;
	      int l,r;
	      int sum,lz;
	  }t[N*40];
	  int a[N],pre[N];
	  void pushup(int x){
	      t[x].sum=t[t[x].ls].sum+t[t[x].rs].sum;
	  }
	  void pushdown(int x,int l,int r){
	      if(t[x].lz){
	          if(!t[x].ls) t[t[x].ls=++id]={0,0,l,mid,0,0};
	          if(!t[x].rs) t[t[x].rs=++id]={0,0,mid+1,r,0,0};
	          int mid=l+r>>1;
	          t[t[x].ls].sum+=t[x].lz*(mid-l+1);
	          t[t[x].rs].sum+=t[x].lz*(r-mid);
	          t[t[x].ls].lz+=t[x].lz;
	          t[t[x].rs].lz+=t[x].lz;
	          t[x].lz=0;
	      }
	  }
	  void change(int&x,int l,int r,int L,int R,int k){
	      if(!x) t[x=++id]={0,0,l,r,0,0};
	      if(L<=l&&r<=R){
	          t[x].sum+=k*(r-l+1);
	          t[x].lz+=k;
	          return;
	      }
	      pushdown(x,l,r);
	      int mid=l+r>>1;
	      if(L<=mid) change(t[x].ls,l,mid,L,R,k);
	      if(R>=mid+1) change(t[x].rs,mid+1,r,L,R,k);
	      pushup(x); 
	  }
	  int query(int&x,int l,int r,int L,int R){
	      if(!x) t[x=++id]={0,0,l,r,0,0};
	      if(L<=l&&r<=R) return t[x].sum;
	      int mid=l+r>>1;
	      pushdown(x,l,r);
	      int res=0;
	      if(L<=mid) res+=query(t[x].ls,l,mid,L,R);
	      if(mid+1<=R) res+=query(t[x].rs,mid+1,r,L,R);
	      pushup(x);
	      return res;
	  }
	  signed main(){
	      ios::sync_with_stdio(false);
	      cin.tie(nullptr);
	      cin>>n>>m;
	      int mx=0;
	      for(int i=1;i<=n;i++) cin>>a[i],mx=max(mx,a[i]);
	      for(int i=1;i<=n;i++) pre[i]=pre[i-1]+a[i];
	      int op,x,y,k;
	      while(m--){
	          cin>>op>>x>>y;
	          if(op==1){
	              cin>>k;
	              change(rt,1,n,x,y,k);
	          }else if(op==2){
	              cout<<query(rt,1,n,x,y)+pre[y]-pre[x-1]<<endl;
	          }
	      }
	      for(int i=1;i<=id;i++) cout<<t[i].ls<<" "<<t[i].rs<<" "<<t[i].l<<" "<<t[i].r<<endl;
	      return 0;
	  }
	  ```
