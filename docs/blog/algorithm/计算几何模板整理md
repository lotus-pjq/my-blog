		  bool cmp_line(line a,line b){//按照极角+左侧排序
		  //先按极角排序
		  //如果极角相同则选择位于左侧的直线
		  //（即保留更左边的直线，因为半平面交是取左侧半平面的交集）。
		      double A=angle(a),B=angle(b);
		      return fabs(A-B)>eps?A<B:(a.e-a.s)*(b.e-a.s)<0;
