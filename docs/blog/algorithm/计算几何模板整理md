		  point Joint(line a,line b){return Joint(a.s,a.e,b.s,b.e);}//求直线a,b的交点
		  bool right(line a,line b,line c){//判断(直线b,c的)交点是否在直线a右侧
		  //（如果在右侧，则说明直线a的半平面不包含该点，因此需要弹出队列中的直线）
		      point p=Joint(b,c);
		      return (a.e-a.s)*(p-a.s)<=0;
