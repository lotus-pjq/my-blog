		  point Joint(point a,point b,point c,point d){//求出直线ab和直线cd的交点
		  	if((d-c)*(b-a)==0) return point(INF,INF);
		  	double t=((a.y-c.y)*(c.x-d.x)-(a.x-c.x)*(c.y-d.y))/((b.x-a.x)*(c.y-d.y)-(b.y-a.y)*(c.x-d.x));
		  	return a+(b-a)*t;
		  }
