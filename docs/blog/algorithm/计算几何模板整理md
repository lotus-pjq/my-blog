		  //球面上两点之间的最短路径距离距离
		  double dis(double lati1,double longi1,double lati2,double longi2,double R){
		  	double pi=acos(-1.0);lati1*=pi/180,longi1*=pi/180,lati2*=pi/180,longi2*=pi/180;//角度转弧度
		  	//球坐标到直角坐标的转换公式：
		  	//x=cos(纬度)*sin(经度)
		  	//y=cos(纬度)*cos(经度)
		  	//z=sin(纬度)
		  	double x1=cos(lati1)*sin(longi1),y1=cos(lati1)*cos(longi1),z1=sin(lati1);
		  	double x2=cos(lati2)*sin(longi2),y2=cos(lati2)*cos(longi2),z2=sin(lati2);
		  	//计算球心角theta,返回球面距离
		  	double theta=acos(x1*x2+y1*y2+z1*z2);return R*theta;
		  }
