		  double angle(point a,point b){return acos((a&b)/len(a)/len(b));}//两向量夹角
		  double cross(point a,point b,point c){return (b.x-a.x)*(c.y-a.y)-(b.y-a.y)*(c.x-a.x);}
		  //直线ab与直线cd无交点: cross(a,b,c)*cross(a,b,d)>0
		  //直线ab与线段cd有交点: cross(a,b,c)*cross(a,b,d)<=0
		  //线段ab与线段cd无交点: cross(a,b,c)*cross(a,b,d)>0||cross(c,d,a)*cross(c,d,b)>0
		  bool intersect(point a,point b,point c,point d){//线段ab和cd是否相交
