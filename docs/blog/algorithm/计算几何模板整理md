		  struct line{point s,e;}a[N];
		  
		  double angle(line a){return atan2(a.e.y-a.s.y,a.e.x-a.s.x);}//直线极角（与x轴正方向的夹角，范围在[-π, π]）
		  bool cmp_line(line a,line b){//按照极角+左侧排序
		  //先按极角排序
		  //如果极角相同则选择位于左侧的直线
		  //（即保留更左边的直线，因为半平面交是取左侧半平面的交集）。
		      double A=angle(a),B=angle(b);
		      return fabs(A-B)>eps?A<B:(a.e-a.s)*(b.e-a.s)<0;
		  }
		  point cross(line a,line b){//求直线a,b的交点
		      point u=a.s-b.s, v=a.e-a.s, w=b.e-b.s;
		      double t=u*w/(w*v);
		      return a.s+v*t;
		  }
		  bool right(line a,line b,line c){//判断(直线b,c的)交点是否在直线a右侧
		  //（如果在右侧，则说明直线a的半平面不包含该点，因此需要弹出队列中的直线）
		      point p=cross(b,c);
		      return (a.e-a.s)*(p-a.s)<=0;
		  }
