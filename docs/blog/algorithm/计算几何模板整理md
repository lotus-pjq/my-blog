		  struct poly:vector<point>{
		  	poly()=default;
		  	poly(vector<point>& v):vector<point>(v){}
		  	//poly(initializer_list<point> init) : vector<point>(init) {}
		      // 多边形面积-鞋带公式
		      double area(){
		          int n=size();
		          if(n<3) return 0;
		          double res=0;
		          for(int i=0,j=n-1;i<n;j=i++) 
		              res+=at(j)*at(i);
		          return fabs(res/2);
		      }
		      // 判断多边形是否为凸多边形
		      bool Is_Convex(){
		          int n=size();
		          if(n<3) return n>0;
		          bool s[3]={0,0,0};
		          for(int i=0,j=n-1,k=n-2;i<n;k=j,j=i++){
		              int cnt=sgn(cross(at(j),at(i),at(k)))+1;// cross(a,b,c)=(b-a)×(c-a)
		              s[cnt]=true;
		              if(s[0] && s[2]) return false;
		          }
		          return true;
		      }
		      // Andrew凸包算法
		      poly Andrew(){
		          poly a=*this;
		          auto cmp=[](point a,point b){return a.x!=b.x?a.x<b.x:a.y<b.y;};
		          sort(a.begin(),a.end(),cmp);
		          a.erase(unique(a.begin(),a.end()),a.end());
		          if(a.size()<=1) return a;
		          poly s;
		          // 下凸包
		          for(const auto &p:a){
		              while(s.size()>=2&&cross(s[s.size()-2],s.back(),p)<=0) s.pop_back();
		  			s.push_back(p);
		          }
		          // 上凸包
		          size_t t=s.size();
		          for(int i=(int)a.size()-2;i>=0;--i){
		              auto &p=a[i];
		              while(s.size()>t&&cross(s[s.size()-2],s.back(),p)<=0) s.pop_back();
		              s.push_back(p);
		          }
		          if(s.size()>1) s.pop_back();// 移除重复起点
		          return s;
		      }
		      //判断点和多边形的位置关系(射线法)__O(N)
		      int In_Poly(point P){
		          int n=size();
		          if(n==0) return 0;
		          if(n==1) return at(0)==P?-1:0;
		          if(n==2) return onSegment(P,at(0),at(1))?-1:0;
		          bool flag=false;
		          for(int i=0,j=n-1;i<n;j=i++){
		              point p1=at(i),p2=at(j);
		              if(onSegment(P,p1,p2)) return -1;
		              if(sgn(P.y-p1.y)>0==sgn(P.y-p2.y)>0) continue;
		              // 使用你的intersect函数判断射线与边相交
		              point ray_end(P.x+1e9,P.y);// 向右的射线
		              if(intersect(P,ray_end,p1,p2)) flag=!flag;
		          }
		          return flag;
		      }
		  	int In_poly(point u){
		          point v(1e9+5,2e8+5); // 射线终点
		          int cnt=0;
		          int n=size();
		          if(n==0) return 0;
		          push_back(at(0));
		          for(int i=0;i<n;i++){
		              if(onSegment(u,at(i),at(i+1))){
		                  pop_back();
		                  return -1;
		              }
		              if(intersect(u,v,at(i),at(i+1))) cnt++;
		          }
		          pop_back();
		          return (cnt&1)?1:0;
		      }
		  	//判断点和凸包的位置关系__O(logN)
		      int In_Convex(point P){
		  	// 要求凸包中的点按极角顺序排列,at(0)作为基点（即Andrew之后）
		  	// 点在多边形边上, 返回 0
		      // 点在多边形内, 返回 1
		      // 点在多边形外, 返回 -1
		          point p0=at(0);
		          auto it=upper_bound(begin()+1,end(),P,
		  		[&p0](const point &a,const point &b){return cross(p0,a,b)>=0;});
		          if(it==begin()+1||it==end()) return -1;
		          point A=*prev(it),B=*it;
		          double crs=cross(A,B,P);// (A-P)×(B-P)
		          return sgn(crs);
		      }
		  	// 多边形重心计算
		      point centroid(){
		          int n=size();
		          if(n==0) return point();
		          double A=0,a;
		          point g;
		          push_back(at(0));
		          for(int i=0;i<n;i++){
		              a=at(i)*at(i+1);
		              A+=a;
		              g=g+(at(i)+at(i+1))*(a/3.0);
		          }
		          pop_back();
		          if(fabs(A)<eps) return point();
		          return g/A;
		      }
		      // 多边形边界整点计数
		      int IntegerPoint_on_polygon(){
		          int n=size();
		          int res=0;
		          for(int i=0,j=n-1;i<n;j=i++){
		              int dx=abs(at(i).x-at(j).x);
		              int dy=abs(at(i).y-at(j).y);
		              res+=__gcd(dx,dy);// 使用__gcd函数
		          }
		          return res;
		      }
		      // 多边形内部整点计数（皮克定理）
		      int IntegerPoint_in_polygon(){
		          double A=area();
		          int B=IntegerPoint_on_polygon();
		          return A-B/2.0+1+eps;// 加eps避免浮点误差
		      }
		      //旋转卡壳求凸包直径
		      double rotating_calipers_diameter(){
		          poly hull=this->Andrew();// 先求凸包
		          int n=hull.size();
		          if(n<=1) return 0;
		          if(n==2) return dis(hull[0],hull[1]);
		          
		          double ans=0;
		          for(int i=0,j=1;i<n;i++){
		              while(cross(hull[i],hull[(i+1)%n],hull[(j+1)%n])>
		                    cross(hull[i],hull[(i+1)%n],hull[j]))
		                  j=(j+1)%n;
		              ans=max(ans,dis(hull[i],hull[j]));
		          }
		          return ans;
		      }
		      //最小外接矩形面积（旋转卡壳）
		      double min_bounding_rectangle(){
		          poly hull=this->Andrew();
		          int n=hull.size();
		          if(n<=2) return 0;
		          double ans=1e18;
		          for(int i=0,j=1,k=1;i<n;i++){
		              point a=hull[i],b=hull[(i+1)%n];
		              //找到距离当前边最远的点
		              while(cross(a,b,hull[(k+1)%n])>cross(a,b,hull[k])) k=(k+1)%n;
		              // 找到在ab垂直方向上投影最远的点
		              point perp((a-b).y,(b-a).x);// 垂直向量
		              while((perp&(hull[(j+1)%n]-a))>(perp&(hull[j]-a))) j=(j+1)%n;
		              double hig=cross(a,b,hull[k])/(b-a).len();
		              double wid=(perp&(hull[j]-a))/perp.len();
		              ans=min(ans,hig*wid);
		          }
		          return ans;
		      }
		  };
