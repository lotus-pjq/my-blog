		  //半平面交
		  double half_plane(int n){
		      sort(a+1,a+n+1,cmp_line);
		      int h=1,t=1;que[1]=a[1];//h:head,t:tail
		      for(int i=2;i<=n;i++){
		          if(angle(a[i])-angle(a[i-1])<eps) continue;
		          while(h<t&&right(a[i],que[t],que[t-1])) t--;//队尾弹出
		          while(h<t&&right(a[i],que[h],que[h+1])) h++;//队首弹出
		          que[++t]=a[i];
		      }
		      while(h<t&&right(que[h],que[t],que[t-1])) t--;
		  
		      if(fabs((que[t].e-que[t].s)*(que[h].e-que[h].s))<eps) return 0;
		      que[++t]=que[h];//封闭多边形
		  
		  	//返回半平面交形成的凸多边形的面积（如果不存在则返回0）-<可按需修改>
		      int k=0;double res=0;
		      for(int i=h;i<t;i++) p[++k]=Joint(que[i],que[i+1]);
		      for(int i=1;i<=k;i++) res+=p[i]*p[i%k+1]/2;
		      return res;
		  }
