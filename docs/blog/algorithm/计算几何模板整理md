		  point aa[N],bb[N];
		  double divide(int l,int r){//最近平面点对:分治+归并排序 O(NlogN)
		  	double d=2e9;
		  	if(l==r) return d;
		  	int m=l+r>>1; point tmp=aa[m];
		  	d=min(divide(l,m),divide(m+1,r));
		  	int i=l,j=m+1,k=0,t=0;
		  	while(i<=m && j<=r)
		  		if(aa[i].y<aa[j].y) bb[k++]=aa[i++];
		  		else bb[k++]=aa[j++];
		  	while(i<=m) bb[k++]=aa[i++];
		  	while(j<=r) bb[k++]=aa[j++];
		  	for(i=l,j=0;i<=r;) aa[i++]=bb[j++];
		  	for(i=0;i<k;i++)
		  		if(fabs(tmp.x-bb[i].x)<d) bb[t++]=bb[i];
		  	for(i=0;i<t;i++)
		  		for(int j=i+1;j<t&&bb[j].y-bb[i].y<d;j++)
		  			d=min(d,dis(bb[i],bb[j]));
		  	return d;
		  }
