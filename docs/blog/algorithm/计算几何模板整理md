		  double JointPoint_line_with_circle(point a,point b,int R,point& pa,point& pb){//线段AB与（圆心为原点，半径为R的）圆的交点
		      point e=getNode(a,b-a,o,rotate(b-a,PI/2));//垂足
		      double d=dis(o,e);
		      if(onSegment(e,a,b)) d=min(dis(o,a),dis(o,b));
		      if(R<=d) return d;
		      double len=sqrt(R*R-dis(o,e)*dis(o,e));
		      pa=e+norm(a-b)*len;
		      pb=e+norm(b-a)*len;
		      return d;//d:线段到圆心的距离;pa,pb:直线与圆的交点
		  }
		  double getArea(point a,point b,int R){//三角形OAB与圆的面积交
		      if(fabs(a*b)<eps) return 0;//case1:共线
		      double da=dis(o,a),db=dis(o,b);
		      if(R>=da&&R>=db) return a*b/2;//case2:ab在圆内
		      point pa,pb;
		      double d=JointPoint_line_with_circle(a,b,R,pa,pb);
		      if(R<=d) return sector(a,b,R);//case3:ab在圆外
		      if(R>=da) return a*pb/2+sector(pb,b,R);//case4,5:a在圆内
		      if(R>=db) return sector(a,pa,R)+pa*b/2;//b在圆内
		      return sector(a,pa,R)+pa*pb/2+sector(pb,b,R);//ab是割线
		  }
		  point Circle_Center(point A,point B,point C){//三角形外接圆圆心
		    	if(fabs((B-A)*(C-A))<eps) return point(INF,INF);//特判共线
		      point AB_mid=(A+B)*0.5;      // AB中点
		      point BC_mid=(B+C)*0.5;      // BC中点
		      point AB_dir=rotate(B-A,PI/2);  // AB的垂直方向
		      point BC_dir=rotate(C-B,PI/2);  // BC的垂直方向
		      return getNode(AB_mid, AB_dir, BC_mid, BC_dir);
		  }
