- 1001电子带负电
	- ![image.png](../assets/image_1753705851162_0.png)
	- ```C++
	  const int N=2e5+5;
	  int n,m,a[N];
	  void solve(){
	      cin>>n; 
	      int mx=0,mn=INF,sum=0;
	      rep(i,1,n){
	          cin>>a[i];
	          mx=max(mx,a[i]);
	          if(a[i]) mn=min(mn,a[i]);
	          sum+=a[i];
	      }
	      if(mx==0){
	          cout<<0<<" "<<(n+1)*n/2%mod*(n+1)%mod*(n+1)%mod<<endl;
	          return;
	      }
	      int head=0,tail=n;
	      rep(i,1,n) if(a[i]){head=i;break;}
	      per(i,n,1) if(a[i]){tail=i;break;}
	      cout<<sum<<" "<<(mn+n+1)*(n-mx+1)%mod*head%mod*(n-tail+1)%mod<<endl;
	  }
