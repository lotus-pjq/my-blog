- 1002海上的太阳 #计算几何
	- ![image.png](../assets/image_1753706736023_0.png){:height 631, :width 1218}
	  ![image.png](../assets/image_1753706778283_0.png){:height 854, :width 778}
	  ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define INF 0x3f3f3f3f3f3f3f3f
	  #define rep(i,j,k) for (int i=j;i<=k;++i)
	  #define per(i,j,k) for (int i=j;i>=k;--i)
	  #define double long double 
	  #define int long long
	  #define endl '\n'
	  const double eps=1e-12;
	  struct building{
	  	double h;
	  	int w,id;
	  	bool operator<(const building&x)const{return id<x.id;}
	  }bui[10];
	  int n,m,a[10],aa[10];
	  double X,Y;
	  double k,b;
	  double posx[10],posy[10];
	  double ff(double x){
	  	double res=0,xx=1;
	  	rep(i,0,m-1){res+=aa[i]*xx;xx*=x;}
	  	return sqrtl(res*res+1L);
	  }
	  double f(double x){
	  	double res=0,xx=1;
	  	rep(i,1,m){xx*=x;res+=a[i]*xx;}
	  	return res;
	  }
	  double simpson(double l,double r){return (r-l)*(ff(l)+ff(r)+4*ff((l+r)/2))/6;}
	  double asr(double l,double r,double ans){
	  	double mid=(l+r)/2, a=simpson(l,mid),b=simpson(mid,r);
	  	if(fabs(a+b-ans)<eps) return ans;
	  	return asr(l,mid,a)+asr(mid,r,b);
	  }
	  void output(double x){
	      static char s[25];
	      sprintf(s,"%.4Le",x);
	      for(int i:{0,1,2,3,4,5,6,7}) printf("%c",s[i]);
	      printf("%c\n",s[strlen(s)-1]);
	  }
	  void solve(){
	  	cin>>n>>m>>X>>Y;
	  	rep(i,1,m) cin>>a[i];
	  	rep(i,1,m) aa[i-1]=a[i]*i;
	  	rep(i,1,n) cin>>bui[i].h>>bui[i].w,bui[i].id=i;
	  	double ans=INF;
	  	do{  
	  		double cur=0;
	          posx[1]=0;
	  		posy[1]=bui[1].h;
	  		rep(i,2,n){
	  			double h=bui[i].h,w=bui[i].w;
	              //约束1
	  			k=(Y-posy[i-1])/(X-posx[i-1]);
	  			b=Y-k*X;
	  			double l=posx[i-1],r=1e10,mid;
	  			while(r-l>eps){
	  				mid=(l+r)/2;
	  				if(f(mid)-k*mid-b>eps) r=mid;
	  				else l=mid;
	  			}
	              //约束2
	  			double sav;
	  			double R=max(h,bui[i-1].h);
	  			double ll=posx[i-1],rr=posx[i-1]+R;
	  			while(rr-ll>eps){
	  				mid=(ll+rr)/2;
	  				double yy=sqrtl(fabs(R*R-(mid-posx[i-1])*(mid-posx[i-1])))+(posy[i-1]-bui[i-1].h);
	  				sav=f(mid);
	  				if(sav-yy>eps) rr=mid;
	  				else ll=mid;
	  			}
	  			if(l>ll) posx[i]=l,posy[i]=k*l+b+h;
	  			else posx[i]=ll,posy[i]=sav+h;
	  			double dis=asr(0,posx[i],simpson(0,posx[i]));
	  			cur+=dis*w;
	  		}
	  		ans=min(ans,cur);
	      }while(next_permutation(bui+1,bui+1+n));  
	  	output(ans);
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	int t;cin>>t;
	  	while(t--) solve();
	  	return 0;
	  }
	  ```
