- ## [I-BenzenE_2026牛客寒假算法基础集训营3](https://ac.nowcoder.com/acm/contest/120563/I)
	- code
		- ```C++
		        
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e5+5;
		  int	a[N],b[N];
		  bool flip[N];
		  void solve(){
		  	int n;cin>>n;
		  	int x=0;
		  	for(int i=1;i<=n;i++) cin>>a[i],x^=a[i];
		  	for(int i=1;i<=n;i++) cin>>b[i];
		  	if(x==0){
		  		for(int i=1;i<=n;i++) cout<<a[i]<<((i==n)?'\n':' ');
		  		return;
		  	}
		  	int bas[30]={}; //线性基中每个位置的值
		  	int msk[30]={};//记录该基向量由哪些原始d值组合而成（30位掩码）
		  	int idx[30]={}; //第k个插入的基向量对应的原始下标
		  	int cnt=0;        //已插入的基向量数量
		  	for(int i=1;i<=n;i++){
		  		int d=a[i]^b[i];
		  		if(d==0) continue;
		  		int cur=d;
		  		int comp=(1<<cnt);//组成:暂时标记为第m个基向量
		  		for(int bit=29;bit>=0;bit--){
		  			if(((cur>>bit)&1)==0) continue;
		  			if(!bas[bit]){
		  				bas[bit]=cur;
		  				msk[bit]=comp;
		  				idx[cnt++]=i;
		  				break;
		  			}
		  			cur^=bas[bit];
		  			comp^=msk[bit];//同步维护
		  		}
		  		if(cnt>=30) break;
		  	}
		  	int cur=x;
		  	int res=0;
		  	for(int bit=29;bit>=0;bit--){
		  		if(((cur>>bit)&1)==0) continue;
		  		if(!bas[bit]) continue;
		  		cur^=bas[bit];
		  		res^=msk[bit];
		  	}
		  	if(cur!=0) cout<<-1<<endl;
		  	else{
		  		for(int i=1;i<=n;i++) flip[i]=false;
		  		for(int k=0;k<cnt;k++)
		  			if((res>>k)&1) flip[idx[k]]=true;
		  		for(int i=1;i<=n;i++)
		  			cout<<(flip[i]?b[i]:a[i])<<((i==n)?'\n':' ');
		  	}
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
		  ```
