## 板子1：高斯消元构造：#异或
	- #高斯消元
	- 给定 *n* 个整数（数字可能重复），求在这些数中选取任意个，使得他们的异或和最大。
	- ### 用高斯消元得到的线性基的性质：
		- 最简阶梯形
		  每一行的 最高有效位（MSB） 互不相同，且 严格右移。
		  ==从上到下单调递减==
		  >0...01....
		  0...001....
		  0...0001...
		- **a[0]** 保存的是 **最高位** 的基向量（最高有效位最靠左）。
		  **a[k-1]** 保存的是 **最低位** 的基向量（最高有效位最靠右）。
		  > **a[0] 的最高位 ≥ a[k-1] 的最高位**，
		  换句话说 **a[0] ≥ a[k-1]**（按最高有效位比较）
	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  int a[55];//下标从0开始
	  int n,k;//k:基向量个数	
	  void Linear_base(){
	  	k=0;
	  	//1.把第i位是1的数换上去
	  	//2.把其他第i位全部消成0
	  	for(int i=62;i>=0;i--){
	  		for(int j=k;j<n;j++)
	  			if(a[j]>>i&1){swap(a[j],a[k]);break;}
	  		if((a[k]>>i&1)==0) continue;
	  		for(int j=0;j<n;j++)
	  			if(j!=k&&(a[j]>>i&1)) a[j]^=a[k];
	  		k++;if(k==n) break;
	  	}
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	cin>>n;
	  	for(int i=0;i<n;i++) cin>>a[i];
	  	Linear_base();
	  	int ans=0;
	  	for(int i=0;i<k;i++) ans^=a[i];
	  	cout<<ans;
	  	return 0;
	  }
	  ```
- ## 第K小异或和 #高斯消元构造线性基
	- HDU 3949XOR
	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  int a[55];//下标从0开始
	  int n,k;//k:基向量个数	
	  void Linear_base(){
	  	k=0;	
	  	//1.把第i位是1的数换上去
	  	//2.把其他第i位全部消成0
	  	for(int i=62;i>=0;i--){
	  		for(int j=k;j<n;j++)
	  			if(a[j]>>i&1){swap(a[j],a[k]);break;}
	  		if((a[k]>>i&1)==0) continue;
	  		for(int j=0;j<n;j++)
	  			if(j!=k&&(a[j]>>i&1)) a[j]^=a[k];
	  		k++;if(k==n) break;
	  	}
	  }
	  void solve(){
	  	cin>>n;
	  	for(int i=0;i<n;i++) cin>>a[i];
	  	Linear_base();
	  	int q;cin>>q;//查询次数
	  	while(q--){
	  		int x;cin>>x;//第x小
	  		if(k<n) x--;
	  		if(x>=(1ll<<k)) cout<<-1<<endl;
	  		else{
	  			int ans=0;
	  			for(int i=0;i<k;i++)
	  				if(x>>i&1) ans^=a[k-i-1];
	  			cout<<ans<<endl;
	  		}
	  	}
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	int t;cin>>t;
	  	while(t--) solve();
	  	return 0;
	  }
	  ```
- ## 板子2：贪心法构造：#异或
	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  int n,p[64];
	  void insert(int x){//贪心法
	  	for(int i=63;i>=0;--i)
	  		if(x>>i&1){
	  			if(!p[i]){p[i]=x;break;}//不存在则加入
	  			x^=p[i];//存在则异或
	  		}
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	cin>>n;
	  	int x;
	  	for(int i=0;i<n;i++){cin>>x;insert(x);}
	  	int ans=0;
	  	for(int i=63;i>=0;i--) ans=max(ans,ans^p[i]);
	  	cout<<ans;
	  	return 0;
	  }
	  ```
