- ## D #二分
	- 题目
		- ![image.png](../assets/image_1760433186014_0.png)
		- ![image.png](../assets/image_1760433207718_0.png)
	- 思路
		- ![image.png](../assets/image_1760433139578_0.png)
	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  #define rep(i,j,k) for (int i=j;i<=k;++i)
		  const int INF=1e18;
		  const int N=3e5+5;
		  int n,a[N],f[N],s[N];
		  //f[i]:第一个j>=i使得a[j]!=a[i]
		  bool check_l(int x,int pos){
		  	if(pos==1) return false;
		  	// 检查从x到pos-1的区间和是否大于a[pos]，并且x和pos-1之间有至少一个不同的值
		      // 或者x和pos相邻且a[x]>a[pos]
		  	if(x==pos-1) return a[x]>a[pos];
		      return (s[pos-1]-s[x-1]>a[pos])&&(f[x]<pos-1);
		  }
		  bool check_r(int x,int pos){
		  	if(pos==n) return false;
		  	// 检查从pos+1到x的区间和是否大于a[pos]，并且pos+1和x之间有至少一个不同的值
		      // 或者pos和x相邻且a[x]>a[pos]
		  	if(x==pos+1) return a[x]>a[pos];
		      return (s[x]-s[pos]>a[pos])&&(f[pos+1]<x);
		  }
		  void solve(){
		  	cin>>n;
		  	rep(i,1,n) cin>>a[i];
		  	rep(i,1,n) s[i]=s[i-1]+a[i];
		  	// 预处理f数组：记录连续相同值的右边界
		  	for(int l=1,r;l<=n;l=r+1){
		  		r=l;
		  		while(r+1<=n&&a[r+1]==a[l]) r++;
		  		for(int i=l;i<=r;i++) f[i]=r;
		  	}
		  	rep(i,1,n){
		  		int ans=INF;
		  		// 检查直接邻居 , 防止4 4 4 3
		          if(i>1&&a[i-1]>a[i]) ans=min(ans,1LL);
		          if(i<n&&a[i+1]>a[i]) ans=min(ans,1LL);
		  		// 左边
		  		int l=1,r=i-1,mid,l_ans=-1,r_ans=-1;
		  		while(l<=r){
		  			mid=l+r>>1;
		  			if(check_l(mid,i)) l=mid+1,l_ans=mid;
		  			else r=mid-1;
		  		}
		  		if(l_ans!=-1) ans=min(ans,i-l_ans);
		  		// 右边
		  		l=i+1,r=n;
		  		while(l<=r){
		  			mid=l+r>>1;
		  			if(check_r(mid,i)) r=mid-1,r_ans=mid;
		  			else l=mid+1;
		  		}
		  		if(r_ans!=-1) ans=min(ans,r_ans-i);
		  		if(ans==INF) cout<<-1<<" ";
		  		else cout<<ans<<" ";
		  	}
		  	cout<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
		  ```