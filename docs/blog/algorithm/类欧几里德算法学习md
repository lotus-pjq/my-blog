	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  const int mod=998244353;
	  const int inv2=(mod+1)/2;
	  const int inv6=(mod+1)/6;
	  int sum1(int x){return x*(x+1)/2%mod;}
	  int sum2(int x){return x*(x+1)%mod*(2*x+1)%mod*inv6%mod;}
	  void Add(int &x,int y){x=(x+y)%mod;}
	  void Sub(int &x,int y){x=((x-y)%mod+mod)%mod;}
	  struct node{int f,g,h;};
	  node sol(int a,int b,int c,int n){
	  	node res={0,0,0};
	  	if(a==0){
	  		res.f=(n+1)*(b/c)%mod;
	  		res.g=(n+1)*(b/c)%mod*(b/c)%mod;
	  		res.h=sum1(n)*(b/c)%mod;
	  	}else if(a>=c||b>=c){
	  		node tmp = sol(a%c,b%c,c,n);
	  		Add(res.f,sum1(n)*(a/c)%mod);
	          Add(res.f,(b/c)*(n+1)%mod);
	          Add(res.f,tmp.f);
	  		Add(res.g,sum2(n)*(a/c)%mod*(a/c)%mod);
	          Add(res.g,n*(n+1)%mod*(a/c)%mod*(b/c)%mod);
	          Add(res.g,(n+1)*(b/c)%mod*(b/c)%mod);
	          Add(res.g,2*(a/c)*tmp.h%mod);
	          Add(res.g,2*(b/c)*tmp.f%mod);
	          Add(res.g,tmp.g);
	  		Add(res.h,tmp.h);
	          Add(res.h,sum2(n)*(a/c)%mod);
	          Add(res.h,sum1(n)*(b/c)%mod);
	  	}else{
	  		int m=(a*n+b)/c;
	  		node tmp=sol(c,c-b-1,a,m-1);
	  		Add(res.f,n*m%mod);
	          Sub(res.f,tmp.f);
	  		Add(res.g,n*m%mod*(m+1)%mod);
	          Sub(res.g,2*tmp.h);
	          Sub(res.g,2*tmp.f);
	          Sub(res.g,res.f);
	  		Add(res.h,n*m%mod*(n+1)%mod);
	          Sub(res.h,tmp.f);
	          Sub(res.h,tmp.g);
	          res.h=res.h*inv2%mod;
	  	}return res;
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	int t;cin>>t;
	  	while(t--){
	  		int n,a,b,c;cin>>n>>a>>b>>c;
	  		node ans=sol(a,b,c,n);
	  		cout<<ans.f<<" "<<ans.g<<" "<<ans.h<<endl;
	  	}
	  	return 0;
	  }
	  ```
