  #include<bits/stdc++.h>
  using namespace std;
  #define int long long
  #define endl '\n'
  const int N=100;
  int primes[N],cnt,minp[N];
  bool st[N]; 
  void get_primes(int n){
      for(int i=2;i<=n;i++){
          if(!st[i]){
              minp[i]=i;  
              primes[cnt++]=i;  
          }
          for(int j=0;i*primes[j]<=n;j++){
              int t=primes[j]*i; 
              st[t] = true;  
              minp[t]=primes[j]; 
              if(i%primes[j]==0) break;  
          }
      }
  }
  int s,n,ans,a[50];
  void dfs(int x,__int128_t sum){
      if(sum<=n&&sum*primes[x]>n){
          int k=1;
          for(int i=0;i<x;i++){
              k*=(a[i]+1);
          }ans=max(ans,k);
      }
      __int128_t z=sum;
      for(int i=1;i<=50;i++){
          a[x]=i;
          z=z*primes[x];
          if(z>n)return;
          dfs(x+1,z);
      }
  }
  void solve(){
  	ans=s=0;
      cin>>n;
      __int128_t sum=1;
      for(int i=0;;i++){
          if(sum>n) break;
          sum=sum*primes[i];
  		s++;
      }
      dfs(0,1);
      cout<<ans<<endl;
  }
  signed main(){
      ios::sync_with_stdio(0);
      cin.tie(0);cout.tie(0);
      get_primes(100);
      int t=1;cin>>t;
      while(t--){solve();}
  }
