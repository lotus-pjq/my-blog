- ## C #数论 #gcd #差分
	- 题目
		- ![image.png](../assets/image_1761628643838_0.png)
		- ![image.png](../assets/image_1761628669689_0.png)
	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e5+5;
		  int a[N],dif[N];
		  bool cmp(int x,int y){return x>y;}
		  int T=0;
		  const int M=262143;
		  struct E{int v;E*nxt;}*g[M+1],pool[N],*cur=pool,*p;int vis[M+1];
		  void ins(int v){
		  	int u=v&M;
		  	if(vis[u]<T)vis[u]=T,g[u]=NULL;
		  	for(p=g[u];p;p=p->nxt) if(p->v==v) return;
		  	p=cur++;p->v=v;p->nxt=g[u];g[u]=p;
		  }
		  bool ask(int v){
		  	int u=v&M;
		  	if(vis[u]<T) return 0;
		  	for(p=g[u];p;p=p->nxt) if(p->v==v) return 1;
		  	return 0;
		  }
		  void init(){T++,cur=pool;}
		  void solve(){
		  	int n;cin>>n;
		  	init();
		  	for(int i=1;i<=n;i++) cin>>a[i],ins(a[i]);
		  	if(n==1){cout<<1<<endl;return;}
		  	sort(a+1,a+n+1,cmp);
		  	//for(int i=1;i<=n;i++) cerr<<a[i]<<" ";
		  	//cerr<<endl;
		  	for(int i=2;i<=n;i++) dif[i]=a[i-1]-a[i];
		  	// for(int i=1;i<=n;i++) cerr<<dif[i]<<" ";
		  	// cerr<<endl;
		  	int g=a[1]-a[2];
		  	for(int i=2;i<=n;i++) g=__gcd(g,dif[i]);
		  	int num=INF;
		  	for(int i=1;;i++)
		  		if(!ask(a[1]-g*i)){num=i;break;}
		  	int cur=0;
		  	for(int i=2;i<=n;i++) cur+=(a[1]-a[i])/g;
		  	cout<<cur+min(num,n)<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
		  ```
