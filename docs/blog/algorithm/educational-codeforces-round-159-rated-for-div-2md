	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  int task,n,p,L,t;
		  int cal(int k){return k*L+min(2*k,task)*t;}
		  void solve(){
		  	cin>>n>>p>>L>>t;
		  	task=(n+6)/7;
		  	int l=0ll,r=n,ans;
		  	while(l<=r){
		  		int mid=l+r>>1;
		  		if(cal(mid)>=p) ans=mid,r=mid-1;
		  		else l=mid+1;	
		  	}
		  	cout<<n-ans<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
