- E(Easy Version) F(Hard Version) #背包
	- ![image.png](../assets/image_1753699333650_0.png){:height 675, :width 771}
	- 全1的连续子串的贡献很显然为n*(n+1)/2
	- 这个时候可能会脑抽进行贪心，每次取最尽量长的1串。但会发现不符合样例2啊啊啊。
	- 怎么会有人看不出来这是背包，还以为是二分+贪心捏...（所以也体现出自己背包是真的一坨啊...
	- 所以是背包，
	  “1”：容量为1，价值为1
	  “2“：容量为2，价值为3
	  “3”：容量为3，价值为6
	  ......
	- 因为要构造的是价值为k的串，考虑到单个物品的价值是容积平方倍的，故可以考虑容量的上限肯定显然比1e3小
	- dp[i]为价值为i的最短01串的长度
		- 转移：for(i:物体)
		                  for(j:价值）
		                          dp[j]=min(dp[j],dp[j-val[i]]+i+1);
	- 因为需要还原出构造的字符串，记录dp转移的上一步是哪里转移过来，需要一个last数组来记录上一步的点
	                                last[j]=i;
	- 时间复杂度O(N*√N)
	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define INF 0x3f3f3f3f3f3f3f3f
	  #define rep(i,j,k) for (int i=j;i<=k;++i)
	  #define per(i,j,k) for (int i=j;i>=k;--i)
	  //#define mid (l+r>>1)
	  //#define ls x<<1
	  //#define rs x<<1|1
	  #define fi first
	  #define se second
	  #define int long long
	  #define endl '\n'
	  //int up=*max_element(a+1,a+n+1);
	  const int mod=1e9+7;
	  const double PI=acos(-1);
	  const double eps=1e-12;
	  const int N=2e5+5;
	  int val[N],last[N],dp[N];
	  void init(){
	      int tot=sqrt(2*N)+1;
	      rep(i,1,tot) val[i]=i*(i+1)/2;
	      memset(dp,0x3f,sizeof(dp));
	      dp[0]=0;
	      rep(i,1,tot)
	          rep(j,val[i],N-5){
	              if(dp[j-val[i]]+i+1<dp[j]){
	                  last[j]=i;
	                  dp[j]=dp[j-val[i]]+i+1;
	              }
	          }
	  }
	  void solve(){
	      int k;cin>>k;
	      vector<int> ans;
	      while(k){
	          ans.push_back(last[k]);
	          k-=val[last[k]];
	      }
	      for(int i=1;i<=ans[0];i++) cout<<1;
	      for(int i=1;i<ans.size();i++){
	          cout<<0;
	          for(int j=1;j<=ans[i];j++) cout<<1;
	      }
	      cout<<endl;
	  }
	  signed main(){
	      ios::sync_with_stdio(false);
	      cin.tie(nullptr);
	      int t;cin>>t;
	      init();
	      while(t--) solve();
	      return 0;
	  }
