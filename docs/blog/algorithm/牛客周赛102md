- C #模拟
	- ![image.png](../assets/image_1753699235019_0.png){:height 399, :width 785}
	-
	- 操作：选相邻两数进行Flip操作。
	- 好串：不存在相邻两字符相同，即010101...或101010...
	- 考虑两种目标串的次数较小值
	- 只需要模拟即可，考虑操作的必要性：不妨从左往右模拟，如果这个位置不匹配则必须要Flip。
	- （不存在什么最优操作。赛事脑抽在想最优操作之类的，导致想出来的操作不能等效实现还导致操作更劣...感觉不要惧怕模拟，该模拟就模拟）
	- ```C++
	  const int N=2e5+5;
	  int n,m,a[N],b[N];
	  void solve(){
	  	cin>>n;char tmp;
	  	rep(i,1,n) cin>>tmp,a[i]=tmp-'0';
	  	rep(i,1,n) b[i]=a[i];
	  	int cnt1=0,cnt2=0;
	  	//target:010101...
	  	for(int i=1;i<n;i++)
	  		if(i%2==1&&a[i]==1||i%2==0&&a[i]==0){
	  			a[i]=1-a[i];
	  			a[i+1]=1-a[i+1];
	  			cnt1++;
	  		}
	  	if(n%2==1&&a[n]==1||n%2==0&&a[n]==0) cnt1=-1;
	  	//target:101010...
	  	for(int i=1;i<n;i++)
	  		if(i%2==0&&b[i]==1||i%2==1&&b[i]==0){
	  			b[i]=1-b[i];
	  			b[i+1]=1-b[i+1];
	  			cnt2++;
	  		}
	  	if(n%2==1&&b[n]==0||n%2==0&&b[n]==1) cnt2=-1;
	  
	  	if(cnt1==-1&&cnt2==-1) cout<<-1<<endl;
	  	else if(cnt1!=-1&&cnt2!=-1) cout<<min(cnt1,cnt2)<<endl;
	  	else cout<<cnt1+cnt2+1<<endl;
	  }
	  ```
