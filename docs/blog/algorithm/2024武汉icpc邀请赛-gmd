	- ```C++
	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  const int N=2e5+5;
	  int ans;
	  int exgcd(int a,int b,int &x,int &y){//a*x+b*y=gcd
	  	if(b==0){x=1,y=0;return a;}
	  	int d=exgcd(b,a%b,y,x);
	  	y-=a/b*x;
	  	return d;
	  }
	  void cal(int n,int m,int x,int y,int dx,int dy){
	  	for(int l=1,r;l<=n;l=r+1){
	  		r=n/(n/l);
	  		int p=n/l;
	  		int tl=max({(l-x+dx-1)/dx,(y-m/p+dy-1)/dy,0ll});
	  		int tr=min((r-x)/dx,y/dy);
	  		if(tr>=tl){
	  			if(dx>=dy) ans=min(ans, n+m-(x+y+tr*(dx-dy))*p );
	  			else ans=min(ans, n+m-(x+y+tl*(dx-dy))*p );
	  		}
	  	}
	  }
	  void solve(){
	  	int n,m,a,b,k;cin>>n>>m>>a>>b>>k;
	  	ans=n+m;
	  	int x,y;
	  	int g=exgcd(a,b,x,y);
	  	//a*x+b*y=k
	  	x*=k/g;
	  	y*=k/g;
	  	int dx=b/g;
	  	int dy=a/g;
	  	int Xmin,Ymax,Xmax,Ymin;
	  	//取(x,y)=(Xmin,Ymax)
	  	Xmin=(x%dx+dx)%dx;
	  	Ymax=(k-a*Xmin)/b;
	  	Ymin=(y%dy+dy)%dy;
	  	Xmax=(k-b*Ymin)/a;
	  	if(k%g!=0){cout<<ans<<endl;return;}
	  	cal(n,m,Xmin,Ymax,dx,dy);
	  	cal(m,n,Ymin,Xmax,dy,dx);
	  	cout<<ans<<endl;
	  }
	  signed main(){
	      ios::sync_with_stdio(false);
	      cin.tie(nullptr);
	      int t=1;cin>>t;
	      while(t--) solve();
	      return 0;
	  }
	  
