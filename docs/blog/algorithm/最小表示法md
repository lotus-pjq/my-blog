- #字符串 #shift操作
- ### 输出:字典序最小的循环位移序列/字符串
- ### 序列:
	- ```C++
	  // 最小表示法
	  int GetMin(const vector<int>& s) {
	      int n = s.size();
	      if (n == 0) return 0;
	      vector<int> t=s;
	      t.insert(t.end(),s.begin(),s.end());
	      int i=0,j=1,k=0;
	      while(i<n&&j<n&&k<n){
	          if(t[i+k]==t[j+k]) ++k;
	          else{
	              (t[i+k]>t[j+k])?i+=k+1:j+=k+1;
	              if(i==j) ++i;
	              k=0;
	          }
	      }
	      return min(i,j);
	  }
	  // 返回字典序最小的循环数组
	  vector<int> Minvec(const vector<int>& s) {
	      int n=s.size();
	      if(n<=1) return s;
	      int t=GetMin(s);
	      vector<int> res;
	      res.reserve(n);
	      res.insert(res.end(),s.begin()+t,s.end()); // 后半段
	      res.insert(res.end(),s.begin(), s.begin()+t); // 前半段
	  
	      return res;
	  }
	  ```
- ### 字符串:
	- ```C++
	  #include <bits/stdc++.h>
	  using namespace std;
	  //最小表示法
	  int GetMin(const string& s) {
	      int n=s.size();
	      if(n==0) return 0;
	      string t=s+s; // 复制一倍
	      int k=0,i=0,j=1;
	      while(k<n&&i<n&&j<n){
	          if(t[i+k]==t[j+k]) ++k;
	          else{
	              (t[i+k]>t[j+k])?i=i+k+1:j=j+k+1;
	              if(i==j) ++i;
	              k=0;
	          }
	      }
	      return min(i,j);
	  }
	  // 返回字典序最小的循环串
	  string MinStr(const string& s) {
	      int n=s.size();
	      if(n==0) return "";
	      int t=GetMin(s);
	      return s.substr(t)+s.substr(0,t);
	  }
	  
	  signed main() {
	      ios::sync_with_stdio(false);
	      cin.tie(nullptr);
	      int n;cin>>n;
	      string s;cin>>s;
	      cout<<MinStr(s);
	      return 0;
	  }
	  ```
