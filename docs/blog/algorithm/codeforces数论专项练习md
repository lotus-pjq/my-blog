		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=5e5+5;
		  int n,m,op,x,y;
		  int a[N],q[N][3],b[N],res[N];
		  int gcd(int a,int b){
		  	int tmp;
		  	while(b!=0){tmp=a%b;a=b;b=tmp;}
		  	return a;
		  }
		  vector<int> fac[N];
		  void sieve(){
		  	for(int i=1;i<N;i++)
		  		for(int j=i;j<N;j+=i)
		  			fac[j].push_back(i);
		  }
		  void solve(){
		  	int n,m,qn;cin>>n>>m>>qn;
		  	for(int i=1;i<=n;i++) cin>>a[i];
		  	for(int i=1;i<=qn;i++){
		  		cin>>q[i][0];
		  		if(q[i][0]==1) cin>>q[i][1]>>q[i][2];
		  		else cin>>q[i][1];
		  	}
		  	for(int i=1;i<=qn;i++) res[i]=-1;
		  	for(int d:fac[m]){//gcd(m,k)==d
		  		for(int i=1;i<=n;i++) b[i]=a[i]%d;
		  		int sum=0;
		  		for(int i=1;i<=n-1;i++)	
		  			if(b[i]>b[i+1]) sum++;
		  		for(int i=1;i<=qn;i++){
		  			if(q[i][0]==1){
		  				int pos=q[i][1];
		  				if(pos-1>=1&&b[pos-1]>b[pos]) sum--;
		  				if(pos+1<=n&&b[pos]>b[pos+1]) sum--;
		  				b[pos]=q[i][2]%d;
		  				if(pos-1>=1&&b[pos-1]>b[pos]) sum++;
		  				if(pos+1<=n&&b[pos]>b[pos+1]) sum++;
		  			}else if(gcd(q[i][1],m)==d) res[i]=(sum<m/d);
		  		}
		  	}
		  	for(int i=1;i<=qn;i++)
		  		if(res[i]!=-1) cout<<(res[i]?"YES":"NO")<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		  	sieve();
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
		  
		  ```
