		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e5+5;
		  int a[N],cnt[N];
		  bool vis[N];
		  vector<int> divs[N];
		  void sieve(int n){
		      for(int i=2;i<=n;i++)
		          for(int j=i;j<=n;j+=i) divs[j].push_back(i);
		  }
		  void solve(){//只需一直维护前i个数的公因子集合，因为这些数对答案无影响
		  	int n;cin>>n;
		  	vector<int> cur;//cur:（目前）前i个数的公因子集合
		  	for(int i=0;i<=n+1;i++) a[i]=cnt[i]=vis[i]=0;
		  	for(int i=1;i<=n;i++) cin>>a[i];
		  	int ans=0;
		  	for(int i=1;i<=n;i++){
		  		vector<int> nxt;
		  		for(int x:divs[a[i]]){
		  			cnt[x]++;
		  			if(cnt[x]!=i) ans=max(ans,cnt[x]);
		  			else if(!vis[x]){
		  				nxt.push_back(x);
		  				vis[x]=1;
		  			}
		  		}
		  		for(int x:cur){
		  			if(cnt[x]!=i){
		  				ans=max(ans,cnt[x]);
		  				vis[x]=0;
		  			}else nxt.push_back(x);
		  		}
		  		cur=nxt;
		  		cout<<ans<<" ";
		  	}
		  	cout<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		  	sieve(N-2);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
