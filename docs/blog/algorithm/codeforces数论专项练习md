		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  #define INF 0x3f3f3f3f3f3f3f3f
		  const int N=2e5+5;
		  int p[N],delay[N],d[N<<1],a[N],b[N];
		  bool ext[N<<1],vis[N<<1],res[N];
		  struct que{
		  	int pos,id;
		  	bool operator<(const que&x)const{return pos>x.pos;}
		  }q[N];
		  bool dfs(int x){
		  	if(x==-1) return true;
		  	if(vis[x]) return ext[x];
		  	vis[x]=true;
		  	ext[x]=dfs(d[x]);
		  	return ext[x];
		  }
		  void solve(){
		  	int n,k;cin>>n>>k;
		  	for(int i=1;i<=n;i++) cin>>p[i];
		  	for(int i=1;i<=n;i++) cin>>delay[i];
		  	int qn;cin>>qn;
		  	for(int i=1;i<=qn;i++) cin>>q[i].pos,q[i].id=i;
		  	sort(q+1,q+qn+1);
		  	//1...n: 红灯的时候往右边走
		  	//n+1...2n:红灯的时候往左边走
		  	for(int i=1;i<=2*n;i++) d[i]=-1;//-1 means exit
		  	for(int i=1;i<=n;i++) a[i]=(p[i]-delay[i]+k)%k;
		  	map<int,int> idx;
		  	for(int i=n;i>=1;i--){
		  		if(idx.count(a[i])) d[i]=idx[a[i]]+n;
		  		idx[a[i]]=i;
		  	}
		  	for(int i=1;i<=n;i++) b[i]=(p[i]+delay[i])%k;
		  	idx.clear();
		  	for(int i=1;i<=n;i++){
		  		if(idx.count(b[i])) d[i+n]=idx[b[i]];
		  		idx[b[i]]=i;
		  	}
		  	for(int i=1;i<=2*n;i++) ext[i]=vis[i]=0;
		  	for(int i=1;i<=n+n;i++) dfs(i);
		  	for(int i=1;i<=qn;i++) res[i]=1;
		  	int ai=n;
		  	idx.clear();
		  	for(int i=1;i<=qn;i++){
		  		while(ai>=0&&p[ai]>=q[i].pos){
		  			idx[a[ai]]=ai;
		  			ai--;
		  		}
		  		if(!idx.count(q[i].pos%k)) res[q[i].id]=true;
		  		else res[q[i].id]=ext[idx[q[i].pos%k]+n];
		  	}
		  	for(int i=1;i<=qn;i++) cout<<(res[i]?"YES":"NO")<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
