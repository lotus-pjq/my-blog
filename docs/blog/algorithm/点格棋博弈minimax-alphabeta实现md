	                int value;
	                if (scored) {
	                    // 如果得分了，继续当前玩家的回合，但深度减1
	                    value = miniMax(depth - 1, false, alpha, beta);
	                } else {
	                    // 如果没有得分，切换玩家，深度减1
	                    value = miniMax(depth - 1, true, alpha, beta);
	                }
	                
	                // 撤销移动
	                undo_action();
	                
	                bestValue = min(bestValue, value);
	                beta = min(beta, bestValue);
	                
	                if (beta <= alpha) {
	                    break; // Alpha-Beta剪枝
	                }
	            }
	            
	            return bestValue;
	        }
	    }
	  
