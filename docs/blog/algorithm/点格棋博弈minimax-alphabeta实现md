	                  int current_lines = get_box_line_count(xx, yy);
	                  int new_line_count = current_lines + 1;
	                  
	                  if(new_line_count == 4) {
	                      completes_boxes++;  // 完成一个盒子
	                  } else if(new_line_count == 3) {
	                      creates_danger++;   // 创造一个危险的三边盒子
	                  } else if(new_line_count == 2) {
	                      creates_safe++;     // 创造一个安全的两边盒子
	                  } else if(new_line_count == 1) {
	                      creates_safe += 0;  // 单边盒子价值较低
	                  }
	              }
	          }
	          
	          // 智能评分逻辑
	          int score = 0;
	          
	          if(completes_boxes > 0) {
	              // 能立即得分是最好的情况
	              score += 25 * completes_boxes;
	              
	              // 如果能完成多个盒子，额外奖励
	              if(completes_boxes >= 2) {
	                  score += 20;
	              }
	          } else {
