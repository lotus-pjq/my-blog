	              if(scored) moveValue=miniMax(DEPTH,true,alpha,beta,node_count);
	              else moveValue=miniMax(DEPTH-1,false,alpha,beta,node_count);
	              
	              undo_action();
	              
	              if(moveValue>bestValue){
	                  bestValue=moveValue;
	                  bestMove=move;
	              }
	              alpha=max(alpha,bestValue);
	              
	              // 如果找到明显优势的移动，可以提前返回
	              if(bestValue > 80) break;
	          }
	          return bestMove;
	      }
	      
