	                        num_lines++;
	                    }
	                }
	                if (num_lines == 3) {
	                    score += 10; // 能立即得分的动作价值最高
	                }
	            }
	        }
	        
	        // 检查这个动作是否会制造危险（让对手有机会立即得分）
	        for (int i = 0; i < 4; i++) {
	            int xx = x + dirs[i][0];
	            int yy = y + dirs[i][1];
	            if (in_board(xx, yy) && xx % 2 == 1 && yy % 2 == 1) {
