	    int evaluate() const {
	        int score_diff;
	        if (curr_player == 0) {
	            score_diff = scores[0] - scores[1];
	        } else {
	            score_diff = scores[1] - scores[0];
	        }
	        
	        // 计算潜在威胁：统计即将完成的格子
	        int potential_boxes = 0;
	        int danger_boxes = 0;
	        
	        for (int y = 1; y < ysize; y += 2) {
	            for (int x = 1; x < xsize; x += 2) {
	                if (board[y][x] == GRID_BOX) {
	                    int num_lines = 0;
	                    // 检查格子四周的边
	                    for (int j = 0; j < 4; j++) {
	                        int xxx = x + dirs[j][0];
	                        int yyy = y + dirs[j][1];
	                        if (in_board(xxx, yyy) && board[yyy][xxx] == GRID_EDGE_USED) {
	                            num_lines++;
	                        }
	                    }
	                    
	                    // 根据边数评估潜在价值
	                    switch (num_lines) {
	                        case 3: potential_boxes += 4; break; // 高风险高回报
	                        case 2: potential_boxes += 1; break; // 中等潜力
	                        case 1: potential_boxes += 0; break; // 低潜力
	                        case 0: potential_boxes += 0; break;
	                    }
	                    
	                    // 特别关注危险位置（对手即将得分的位置）
	                    if (num_lines == 3) {
	                        // 检查这个格子是否会被对手立即得分
	                        danger_boxes += 2;
	                    }
	                }
	            }
	        }
	        
	        // 综合评估：当前分数差 + 潜在机会 - 危险威胁
	        return score_diff * 5 + potential_boxes - danger_boxes;
	    }
	  
	    // 动作评估函数 - 评估单个动作的即时价值
	    int evaluate_action(int x, int y) const {
