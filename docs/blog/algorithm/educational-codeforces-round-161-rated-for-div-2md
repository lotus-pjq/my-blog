	- 代码1(标程)
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  #define INF 0x3f3f3f3f3f3f3f3f
		  const int N=3e5+5;
		  int a[N],d[N];
		  void solve(){
		  	int n;cin>>n;
		  	for(int i=1;i<=n;i++) cin>>a[i];
		  	for(int i=1;i<=n;i++) cin>>d[i];
		  	a[0]=a[n+1]=0;	
		  	d[0]=d[n+1]=INF;
		  	set<int> rem,cur;//rem:剩下的，cur:目前候选的
		  	for(int i=0;i<=n+1;i++){
		  		rem.insert(i);
		  		cur.insert(i);
		  	}
		  	for(int z=0;z<n;z++){
		  		set<int> del,nex;//del:删除的,ncur:下一轮加入候选的
		  		for(int i:cur){
		  			auto it=rem.find(i);
		  			if(it==rem.end()) continue;//i已经死了
		  			int prv=*prev(it);
		  			int nxt=*next(it);
		  			if(a[prv]+a[nxt]>d[i]){
		  				del.insert(i);
		  				nex.insert(prv);
		  				nex.insert(nxt);
		  			}
		  		}
		  		cout<<del.size()<<" ";
		  		for(auto it:del) rem.erase(it);
		  		cur=nex;
		  	}
		  	cout<<endl;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      int t=1;cin>>t;
		      while(t--) solve();
		      return 0;
		  }
		  ```
