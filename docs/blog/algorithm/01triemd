- ## 最大异或对【模板】
	- 题目
		- ![image.png](../assets/image_1760857916868_0.png)
	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e5+5;
		  int n,a[N];
		  int t[N*31][2],cnt;
		  void insert(int x){
		  	int p=0;
		  	for(int i=30;i>=0;i--){
		  		int j=x>>i&1;
		  		if(!t[p][j]) t[p][j]=++cnt;
		  		p=t[p][j];
		  	}
		  }
		  int query(int x){
		  	int p=0,res=0;
		  	for(int i=30;i>=0;i--){
		  		int j=x>>i&1;
		  		if(t[p][j^1]){
		  			res+=1<<i;
		  			p=t[p][j^1];
		  		}
		  		else p=t[p][j];
		  	}
		  	return res;
		  }
		  signed main(){
		  	ios::sync_with_stdio(false);
		  	cin.tie(nullptr);
		  	cin>>n;
		  	for(int i=1;i<=n;i++) cin>>a[i],insert(a[i]);
		  	int ans=0;
		  	for(int i=1;i<=n;i++)
		  		ans=max(ans,query(a[i]));
		  	cout<<ans;
		  	return 0;
		  }
