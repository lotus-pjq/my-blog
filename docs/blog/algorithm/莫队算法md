	- P2709代码（优化前）519ms
		- ```c++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e5+5;
		  int n,m,k,B,a[N],c[N],sum,ans[N];
		  struct Q{
		      int l,r,id;
		      bool operator<(const Q&x)const{
		          if(l/B!=x.l/B) return l<x.l;
		          return r<x.r;
		      }
		  }q[N];
		  void add(int x){
		      sum-=c[x]*c[x];
		      c[x]++;
		      sum+=c[x]*c[x];
		  }
		  void del(int x){
		      sum-=c[x]*c[x];
		      c[x]--;
		      sum+=c[x]*c[x];
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      cin>>n>>m>>k;
		      B=sqrt(n);
		      for(int i=1;i<=n;i++) cin>>a[i];
		      for(int i=1;i<=m;i++) cin>>q[i].l>>q[i].r,q[i].id=i;
		      sort(q+1,q+1+m);
		      for(int i=1,l=1,r=0;i<=m;i++){
		          //[l,r]->[q.l,q.r] 1.扩 2.缩
		          while(l>q[i].l) add(a[--l]);
		          while(r<q[i].r) add(a[++r]);
		          while(l<q[i].l) del(a[l++]);
		          while(r>q[i].r) del(a[r--]);
		          ans[q[i].id]=sum;
		      }
		      for(int i=1;i<=m;i++) cout<<ans[i]<<endl;
		      return 0;
		  }
		  ```
