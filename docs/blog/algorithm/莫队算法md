		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=1e6+5;
		  int n,m,ans[N],cnt[N],a[N];
		  int B,cntq,cntr,sum;
		  struct query{
		      int l,r,tim,id;
		      bool operator<(const query&x)const{
		          if(l/B!=x.l/B) return l<x.l;
		          if(r/B!=x.r/B) return r<x.r;
		          return tim<x.tim;
		      }
		  }q[N];
		  struct reset{
		      int pos,val;
		  }re[N];
		  void add(int x){
		      if(cnt[x]==0) sum++;
		      cnt[x]++;
		  }
		  void del(int x){
		      cnt[x]--;
		      if(cnt[x]==0) sum--;
		  }
		  signed main(){
		      ios::sync_with_stdio(false);
		      cin.tie(nullptr);
		      cin>>n>>m;
		      B=pow(n,2.0/3);
		      char op;int x,y;
		      for(int i=1;i<=n;i++) cin>>a[i];
		      for(int i=1;i<=m;i++){
		          cin>>op>>x>>y;
		          if(op=='Q') q[++cntq]={x,y,cntr,cntq};
		          else re[++cntr]={x,y};
		      }
		      sort(q+1,q+cntq+1);
		  //x表示在正序时间轴上已经处理过当前x的操作
		      for(int i=1,l=1,r=0,x=0;i<=cntq;i++){
		          //[l,r,t]->[q.l,q.r,q.tim] 
		          while(l>q[i].l) add(a[--l]);
		          while(l<q[i].l) del(a[l++]);
		          while(r>q[i].r) del(a[r--]);
		          while(r<q[i].r) add(a[++r]);
		          while(x<q[i].tim){
		      //时间戳变大,先后移时间戳再操作
		              int p=re[++x].pos;
		              //位置p介于[l,r],先删旧数,后加新数
		              if(l<=p&&p<=r) del(a[p]),add(re[x].val);
		              swap(a[p],re[x].val);
		          }
		          while(x>q[i].tim){
		      //时间戳变小，先还原当前操作再倒退时间戳
		              int p=re[x].pos;
		              if(l<=p&&p<=r) del(a[p]),add(re[x].val);
		              swap(a[p],re[x--].val);
		          }
		          ans[q[i].id]=sum;
		      }
		      for(int i=1;i<=cntq;i++) cout<<ans[i]<<endl;
		      return 0;
		  }
