- ### F.连线博弈 #博弈论 #异或哈希
	- 题面：
		- ![statement_14552_01.png](../assets/statement_14552_01_1758539875527_0.png){:height 612, :width 427}
	- 分析：
		- > Tip1:要注意要看成始终"环"的状态，不存在线的状态。
		  > Tip2:就算点不相邻也可能会在同一个"环"中、
		- ![v2-cc9eacd23a68d593c825b7bf867ee7c2_1440w.jpg](../assets/v2-cc9eacd23a68d593c825b7bf867ee7c2_1440w_1758539461187_0.jpg){:height 244, :width 392}
		- 为找到初始棋盘的子游戏大小，考虑 Xor-Hash，即对圆环 Hash 染色，颜色（即异或值）相同的在一个子游戏中。
		- 博弈部分是模板题：sg 打表，同一状态下的子游戏 - 异或；同一游戏后续的子状态 - mex。
		  打表发现规律：34个一组循环，其中前两组有部分点不符合后续循环规律
		  ![image.png](../assets/image_1758539733975_0.png){:height 199, :width 602}
	- 代码：
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=2e2+5;
		  mt19937_64 rg(random_device{}());
		  int sg[N];
		  int SG(int x){
		  	if(x<=200) return sg[x];
		  	else return sg[x%34+102];
		  }
		  int init_SG(int x){
		  	if(sg[x]!=-1) return sg[x];
		  	set<int> st;
		  	for(int i=0;i<=x-2;i++)
		  		st.insert(init_SG(i)^init_SG(x-i-2));
		  	int mex=0;
		  	while(st.count(mex)) mex++;
		  	return sg[x]=mex;
		  }
		  void solve(){
		  	int n,m;cin>>n>>m;
		  	pair<int,int> pr[2*m+5];
		  	int tot=0;
		  	for(int i=1,l,r;i<=m;i++){
		  		cin>>l>>r;
		  		int rnd=rg();
		  		pr[++tot]={l,rnd},pr[++tot]={r,rnd};
		  	}
		  	sort(pr+1,pr+tot+1);
		  	pr[++tot]={n,0};
		  	map<int,int> seg;
		  	int lst=-1,cur=0;
		  	for(int i=1,x,val;i<=tot;i++){
		  		x=pr[i].first,val=pr[i].second;
		  		seg[cur]+=x-lst-1;
		  		cur^=val;
		  		lst=x;
		  	}
		  	int ans=0;
		  	for(auto [_,x]:seg) ans^=SG(x);
		  	if(ans) cout<<"YES"<<endl;
		  	else cout<<"NO"<<endl;
		  }
		  signed main(){
		  	ios::sync_with_stdio(false);
		  	cin.tie(nullptr);
		  	memset(sg,-1,sizeof(sg));
		  	sg[0]=0,sg[1]=0,sg[2]=1,sg[3]=1;
		  	for(int i=1;i<=200;i++) init_SG(i);
		  	int t;cin>>t;
		  	while(t--) solve();
		  	return 0;
		  }
		  ```
