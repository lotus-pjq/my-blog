- ### G.序列与整数对 #分块
	- 题面：
		- ![statement_14553_01.png](../assets/statement_14553_01_1758540558941_0.png){:height 347, :width 395}
	- 法一（O(q*logn*√n)）
		- ![248316b2875cf6b9e362954eb807ee51.png](../assets/248316b2875cf6b9e362954eb807ee51_1758543622726_0.png)
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  signed main(){
		  	ios::sync_with_stdio(false);
		  	cin.tie(nullptr);
		  	int n,q,x,B;cin>>n>>q;
		  	B=500;
		  	map<int,vector<int>> mp;
		  	for(int i=1;i<=n;i++){
		  		cin>>x;
		  		mp[x].push_back(i);
		  	}
		  	map<pair<int,int>,int> ans;
		  	while(q--){
		  		int x,y;cin>>x>>y;
		  		if(x==y){
		  			int siz=mp[x].size();
		  			cout<<siz*(siz-1)/2<<endl;
		  			continue;
		  		}
		  		if(ans.count({x,y})){
		  			cout<<ans[{x,y}]<<endl;
		  			continue;
		  		}
		  		int res=0;
		  		vector<int> vecx=mp[x],vecy=mp[y];
		  		if(vecx.size()<vecy.size()){
		  			for(int p:vecx)
		  				res+=vecy.end()-lower_bound(vecy.begin(),vecy.end(),p);
		  		}else{
		  			for(int p:vecy)
		  				res+=lower_bound(vecx.begin(),vecx.end(),p)-vecx.begin();
		  		}
		  		if(min(vecx.size(),vecy.size())>B) ans[{x,y}]=res;
		  		cout<<res<<endl;
		  	}
		   	return 0;
		  }
		  ```
