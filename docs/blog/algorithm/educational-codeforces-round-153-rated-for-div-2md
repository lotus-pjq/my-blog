- ## C #博弈
	- 题目
		- ![image.png](../assets/image_1758876272717_0.png)
	- 代码
		- ```C++
		  #include<bits/stdc++.h>
		  using namespace std;
		  #define int long long
		  #define endl '\n'
		  const int N=3e5+5;
		  int n,m,a[N];
		  void solve(){
		  	cin>>n;
		  	int ans=0;
		  	int mn=n+1,mnWin=n+1,x;
		  	while(n--){
		  		cin>>x;
		  		if(mn<x&&x<mnWin){
		  			ans+=1;
		  			mnWin=x;
		  		}
		  		mn=min(mn,x);
		  	}
		  	cout<<ans<<endl;
		  }
		  signed main(){
		  	ios::sync_with_stdio(false);
		  	cin.tie(nullptr);
		  	int t;cin>>t;
		  	while(t--) solve();
		  	return 0;
		  }
