	  #include<bits/stdc++.h>
	  using namespace std;
	  #define int long long
	  #define endl '\n'
	  #define pb push_back
	  const int N=2e4+5;
	  int dep[N],fa[N][16];
	  int pos[N][61];
	  vector<int> g[N];
	  int p[N][61];
	  int n,q,a[N],x,y;
	  int tmp[61];
	  void insert(int u,int f){
	  	for(int i=0;i<=60;i++)
	  		p[u][i]=p[f][i],pos[u][i]=pos[f][i];
	  	int x=a[u],P=u;
	  	for(int i=60;i>=0;i--){
	  		if((x>>i)&1){
	  			if(!p[u][i]){p[u][i]=x;pos[u][i]=P;return;}
	  			if(dep[pos[u][i]]<dep[P])
	  				swap(x,p[u][i]),swap(P,pos[u][i]);
	  			x^=p[u][i];
	  		}
	  	}
	  }
	  void dfs(int u,int f){
	  	dep[u]=dep[f]+1;fa[u][0]=f;
	  	for(int i=1;i<=15;i++)
	  		fa[u][i]=fa[fa[u][i-1]][i-1];
	  	insert(u,f);
	  	for(int v:g[u])
	  		if(v!=f) dfs(v,u);
	  }
	  int LCA(int x,int y){
	  	if(dep[x]<dep[y]) swap(x,y);
	  	for(int i=15;i>=0;i--)
	  		if(dep[fa[x][i]]>=dep[y]) x=fa[x][i];
	  	if(x==y) return x;
	  	for(int i=15;i>=0;i--)
	  		if(fa[x][i]!=fa[y][i]) x=fa[x][i],y=fa[y][i];
	  	return fa[x][0];
	  }
	  int query(int x,int y){
	  	int lca=LCA(x,y);
	  	memset(tmp,0,sizeof(tmp));
	  	for(int i=60;i>=0;i--)
	  		if(dep[pos[x][i]]>=dep[lca]) tmp[i]=p[x][i];
	  	for(int i=60;i>=0;i--)
	  		if(dep[pos[y][i]]>=dep[lca]){
	  			int val=p[y][i];
	  			for(int j=i;j>=0;j--)
	  				if(val>>j&1){
	  					if(!tmp[j]){tmp[j]=val;break;}
	  					val^=tmp[j];
	  				}
	  		}
	  	int ans=0;
	  	for(int i=60;i>=0;--i) ans=max(ans,ans^tmp[i]);
	  	return ans;
	  }
	  signed main(){
	  	ios::sync_with_stdio(false);
	  	cin.tie(nullptr);
	  	cin>>n>>q;
	  	for(int i=1;i<=n;i++) cin>>a[i];
	  	for(int i=1,x,y;i<n;i++) cin>>x>>y,g[x].pb(y),g[y].pb(x);
	  	dfs(1,0);
	  	while(q--){
	  		cin>>x>>y;
	  		cout<<query(x,y)<<endl;
	  	}
	  	return 0;
	  }
